{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": "./_company",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["_company/src"],
  "exclude": [
    "node_modules",
    "00_Raw",
    "40_템플릿",
    "_company/sessions",
    "_company/00_Raw",
    "_company/components",
    "_company/hooks",
    "_company/pages",
    "_company/dist",
    "_company/.next",
    "_company/out",
    "_company/build"
  ]
}
