{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QLossDatasetSchema",
  "description": "Schema validation for QLoss dataset v1.",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "description": { "type": "string" },
        "required_action": { "type": "string" }
      },
      "required": ["version", "description", "required_action"]
    },
    "qloss_scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "scenario_name": { "type": "string" },
          "industry": { "type": "string" },
          "risk_type": { "type": "string" },
          "triggering_event": { "type": "string" },
          "impacted_asset": { "type": "string" },
          "estimated_loss_range_usd": {
            "type": "object",
            "properties": {
              "min": { "type": "integer" },
              "max": { "type": "integer" }
            },
            "required": ["min", "max"]
          },
          "reasoning": { "type": "string" },
          "data_source_needed": { "type": "string" }
        },
        "required": [
          "id",
          "scenario_name",
          "industry",
          "risk_type",
          "triggering_event",
          "impacted_asset",
          "estimated_loss_range_usd",
          "reasoning",
          "data_source_needed"
        ]
      }
    }
  },
  "required": ["metadata", "qloss_scenarios"]
}