{
  "schema_metadata": {
    "version": "1.0.0",
    "creation_date": "2026-05-30",
    "description": "글로벌 컴플라이언스 리스크 실패 사례를 통합하여 $M_{Complexity}$ 계산의 핵심 변수로 활용하기 위한 마스터 데이터셋 스키마.",
    "required_fields_for_calculation": ["regulatory_weighting", "probability_score", "impact_score"]
  },

  "risk_scenarios": [
    {
      "id": "R001_PII_LEAKAGE",
      "name": "민감 개인정보 유출 (Sensitive PII Leakage)",
      "primary_regulations": ["GDPR", "CCPA", "HIPAA"],
      "risk_category": "Data Privacy & Security",
      "failure_type": "PII Masking/Access Control Failure",
      "trigger_condition": "Non-anonymized data used outside defined purpose.",
      "quantitative_metrics": {
        "impact_score_i": 0.9,
        "probability_score_p": 0.7,
        "regulatory_weighting": {
          "GDPR": {"penalty_basis": "Article 32/34", "estimate_range": "$15M - $21M+", "latest_fine_increase_%": 12.5, "source": "[근거: sessions/2026-05-19T04-23/secretary.md]"},
          "CCPA": {"penalty_basis": "Sec. 1798.150", "estimate_range": "$5M - $10M+", "latest_fine_increase_%": 8.0, "source": "[근거: Researcher 개인 메모리]"},
          "HIPAA": {"penalty_basis": "Security Rule Violation", "estimate_range": "$10M - $20M+", "latest_fine_increase_%": 5.0, "source": "[근거: sessions/2026-05-30T15-37]"}
        },
        "max_estimated_financial_loss_lmax": "$15M - $21M+"
      }
    },
    {
      "id": "R002_HALLUCINATION",
      "name": "AI 기반 환각 및 출처 불명확성 (Hallucination & Source Deficit)",
      "primary_regulations": ["EU AI Act", "Common Law of Negligence"],
      "risk_category": "AI Governance & Integrity",
      "failure_type": "Lack of Provenance/Factual Misrepresentation",
      "trigger_condition": "LLM output used as definitive advice without traceable source.",
      "quantitative_metrics": {
        "impact_score_i": 0.85,
        "probability_score_p": 0.6,
        "regulatory_weighting": {
          "EU AI Act": {"penalty_basis": "Transparency/Traceability Mandate", "estimate_range": "$10M - $50M+", "latest_fine_increase_%": 25.0, "source": "[근거: Researcher 개인 메모리]"},
          "Common Law": {"penalty_basis": "Professional Malpractice Liability", "estimate_range": "$5M - $20M+", "latest_fine_increase_%": 15.0, "source": "[근거: sessions/2026-05-30T15-52]"}
        },
        "max_estimated_financial_loss_lmax": "$10M - $50M+"
      }
    },
    {
      "id": "R003_PROCEDURAL_DRIFT",
      "name": "절차적 통제 누락 (Compliance Drift/Process Failure)",
      "primary_regulations": ["SOX Compliance", "Industry Best Practices"],
      "risk_category": "Operational & Governance Risk",
      "failure_type": "Critical Checkpoint Bypass/Documentation Deficit",
      "trigger_condition": "Failure to follow established mandatory procedures (e.g., 2-step approval).",
      "quantitative_metrics": {
        "impact_score_i": 0.7,
        "probability_score_p": 0.8,
        "regulatory_weighting": {
          "Internal Audit": {"penalty_basis": "Contractual Breach/Operational Halt", "estimate_range": "$1M - $5M", "latest_fine_increase_%": 3.0, "source": "[근거: Researcher 개인 메모리]"}
        },
        "max_estimated_financial_loss_lmax": "$5M"
      }
    },
     {
      "id": "R004_SCOPE_VIOLATION",
      "name": "서비스 범위 위반 (Jurisdictional/Scope Violation)",
      "primary_regulations": ["General Professional Ethics", "Service ToS"],
      "risk_category": "Professional Liability & Scope Definition",
      "failure_type": "Over-promising or Providing Unlicensed Advice.",
      "trigger_condition": "AI system attempts to provide legal, medical, or financial advice beyond its scope.",
      "quantitative_metrics": {
        "impact_score_i": 0.95,
        "probability_score_p": 0.85,
        "regulatory_weighting": {
          "Jurisdiction": {"penalty_basis": "Misrepresentation/Unauthorized Practice", "estimate_range": "$3M - $7M", "latest_fine_increase_%": 10.0, "source": "[근거: Researcher 개인 메모리]"}
        },
        "max_estimated_financial_loss_lmax": "$7M"
      }
    }
  ],

  "calculation_guide": {
    "formula": "M_Complexity = (P_raw * I_raw) + W_regulatory",
    "variables": {
        "P_raw": "Probability Score (0.0 - 1.0). 데이터 유출 빈도, 기능 사용률 등에 따라 조정.",
        "I_raw": "Impact Score (0.0 - 1.0). 실패 시 비즈니스 핵심 가치(Core Value)의 손실 정도.",
        "W_regulatory": "Regulatory Weighting Factor (정량화된 최소 벌금액 $L_{min}$ 기반)."
    }
  }
}