# 자동 생성 — Connect AI 1인 기업 모드
# 시크릿·API 키 보호
_agents/*/config.md
# 도구 설정 JSON 안에 API 키·텔레그램 봇 토큰이 들어갈 수 있어 git에서 제외
_agents/*/tools/*.json
_agents/*/tools/youtube_account.json

# 외부 API 응답 캐시 (재현 가능)
_cache/

# 대용량 임시 산출물
_tmp/
*.log

# Python cache & compile artifacts
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/

# IDE & Editor files
**/.vscode/
**/.idea/
**/*.suo
**/*.ntvs*
**/*.njsproj
**/*.sln
**/*.swp
**/.DS_Store

# Node dependencies & logs
**/node_modules/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# OS files
**/Thumbs.db
**/Desktop.ini

# Next.js build output
_company/.next/
.next/

# Agent runtime PID files
*.pid
**/*.pid
